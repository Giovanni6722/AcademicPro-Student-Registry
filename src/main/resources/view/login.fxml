<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<GridPane fx:id="rootpane" alignment="CENTER"
          maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
          prefHeight="600.0" prefWidth="900.0"
          styleClass="login_grid"
          xmlns="http://javafx.com/javafx/20.0.1"
          xmlns:fx="http://javafx.com/fxml/1"
          fx:controller="viewmodel.LoginController">
    <columnConstraints>
        <ColumnConstraints hgrow="SOMETIMES" prefWidth="200.0"/>
        <ColumnConstraints hgrow="SOMETIMES" prefWidth="300.0"/>
        <ColumnConstraints hgrow="SOMETIMES" prefWidth="400.0"/>
    </columnConstraints>
    <rowConstraints>
        <RowConstraints prefHeight="80.0"  vgrow="SOMETIMES"/>
        <RowConstraints prefHeight="100.0" vgrow="SOMETIMES"/>
        <RowConstraints prefHeight="30.0"  vgrow="NEVER"/>
        <RowConstraints prefHeight="45.0"  vgrow="NEVER"/>
        <RowConstraints prefHeight="30.0"  vgrow="NEVER"/>
        <RowConstraints prefHeight="45.0"  vgrow="NEVER"/>
        <RowConstraints prefHeight="20.0"  vgrow="NEVER"/>
        <RowConstraints prefHeight="55.0"  vgrow="NEVER"/>
        <RowConstraints prefHeight="55.0"  vgrow="NEVER"/>
        <RowConstraints prefHeight="30.0"  vgrow="NEVER"/>
        <RowConstraints prefHeight="100.0" vgrow="SOMETIMES"/>
    </rowConstraints>
    <children>

        <!-- Title -->
        <HBox alignment="CENTER" GridPane.columnSpan="3" GridPane.rowIndex="1">
            <Label alignment="CENTER" prefWidth="1400.0"
                   styleClass="login_title"
                   text="AcademicPro Student Registry"
                   textAlignment="CENTER" wrapText="true">
                <font><Font name="System Bold" size="38.0"/></font>
            </Label>
        </HBox>

        <!-- Username label (row 2) -->
        <Label text="Username" styleClass="login_label"
               GridPane.columnIndex="1" GridPane.rowIndex="2">
            <font><Font name="System Bold" size="15.0"/></font>
        </Label>

        <!-- Username field (row 3) -->
        <TextField fx:id="usernameTextField"
                   promptText="Enter your username"
                   styleClass="login_text_field"
                   prefWidth="280.0"
                   GridPane.columnIndex="1" GridPane.rowIndex="3"/>

        <!-- Password label (row 4) -->
        <Label text="Password" styleClass="login_label"
               GridPane.columnIndex="1" GridPane.rowIndex="4">
            <font><Font name="System Bold" size="15.0"/></font>
        </Label>

        <!-- Password field (row 5) -->
        <PasswordField fx:id="passwordField"
                       promptText="Enter your password"
                       styleClass="login_password_field"
                       prefWidth="280.0"
                       GridPane.columnIndex="1" GridPane.rowIndex="5"/>

        <!-- Login button (row 7) -->
        <Button fx:id="loginBtn"
                mnemonicParsing="false" onAction="#login"
                text="Login"
                prefHeight="42.0" prefWidth="220.0"
                styleClass="login_btn_primary"
                GridPane.columnIndex="1" GridPane.rowIndex="7">
            <font><Font name="System Bold" size="16.0"/></font>
        </Button>

        <!-- Create Account button (row 8) -->
        <Button fx:id="signUpButton"
                mnemonicParsing="false" onAction="#signUp"
                text="Create Account"
                prefHeight="42.0" prefWidth="220.0"
                styleClass="login_btn_secondary"
                GridPane.columnIndex="1" GridPane.rowIndex="8">
            <font><Font name="System Bold" size="14.0"/></font>
        </Button>

        <!-- Error label (row 9) -->
        <Label fx:id="errorLabel" text=""
               styleClass="login_error_label"
               wrapText="true" prefWidth="380.0"
               GridPane.columnIndex="1" GridPane.rowIndex="9"
               GridPane.columnSpan="2"/>

    </children>
</GridPane>