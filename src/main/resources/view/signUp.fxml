<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<GridPane alignment="CENTER"
          prefHeight="600.0" prefWidth="900.0"
          styleClass="signup_grid"
          xmlns="http://javafx.com/javafx/20.0.1"
          xmlns:fx="http://javafx.com/fxml/1"
          fx:controller="viewmodel.SignUpController">
    <columnConstraints>
        <ColumnConstraints hgrow="SOMETIMES" prefWidth="180.0"/>
        <ColumnConstraints hgrow="SOMETIMES" prefWidth="160.0"/>
        <ColumnConstraints hgrow="SOMETIMES" prefWidth="280.0"/>
        <ColumnConstraints hgrow="SOMETIMES" prefWidth="280.0"/>
    </columnConstraints>
    <rowConstraints>
        <RowConstraints prefHeight="50.0"  vgrow="SOMETIMES"/>
        <RowConstraints prefHeight="70.0"  vgrow="SOMETIMES"/>
        <RowConstraints prefHeight="20.0"  vgrow="SOMETIMES"/>
        <RowConstraints prefHeight="55.0"  vgrow="SOMETIMES"/>
        <RowConstraints prefHeight="55.0"  vgrow="SOMETIMES"/>
        <RowConstraints prefHeight="55.0"  vgrow="SOMETIMES"/>
        <RowConstraints prefHeight="55.0"  vgrow="SOMETIMES"/>
        <RowConstraints prefHeight="55.0"  vgrow="SOMETIMES"/>
        <RowConstraints prefHeight="30.0"  vgrow="SOMETIMES"/>
        <RowConstraints prefHeight="60.0"  vgrow="SOMETIMES"/>
        <RowConstraints prefHeight="40.0"  vgrow="SOMETIMES"/>
    </rowConstraints>
    <children>
        <HBox alignment="CENTER" GridPane.columnSpan="4" GridPane.rowIndex="1">
            <Label text="Create Your Account" alignment="CENTER"
                   prefWidth="1200.0" styleClass="signup_title">
                <font><Font name="System Bold" size="32.0"/></font>
            </Label>
        </HBox>
        <Label text="First Name" styleClass="signup_label"
               GridPane.columnIndex="1" GridPane.rowIndex="3">
            <font><Font name="System Bold" size="14.0"/></font>
        </Label>
        <VBox alignment="CENTER_LEFT" GridPane.columnIndex="2" GridPane.rowIndex="3">
            <TextField fx:id="firstNameField" promptText="e.g. Jane"
                       styleClass="signup_field" prefWidth="260.0"/>
        </VBox>
        <Label text="Last Name" styleClass="signup_label"
               GridPane.columnIndex="1" GridPane.rowIndex="4">
            <font><Font name="System Bold" size="14.0"/></font>
        </Label>
        <VBox alignment="CENTER_LEFT" GridPane.columnIndex="2" GridPane.rowIndex="4">
            <TextField fx:id="lastNameField" promptText="e.g. Smith"
                       styleClass="signup_field" prefWidth="260.0"/>
        </VBox>
        <Label text="Username" styleClass="signup_label"
               GridPane.columnIndex="1" GridPane.rowIndex="5">
            <font><Font name="System Bold" size="14.0"/></font>
        </Label>
        <VBox alignment="CENTER_LEFT" GridPane.columnIndex="2" GridPane.rowIndex="5">
            <TextField fx:id="usernameField" promptText="3–30 chars, letters/digits/._-"
                       styleClass="signup_field" prefWidth="260.0"/>
        </VBox>
        <Label text="Password" styleClass="signup_label"
               GridPane.columnIndex="1" GridPane.rowIndex="6">
            <font><Font name="System Bold" size="14.0"/></font>
        </Label>
        <VBox alignment="CENTER_LEFT" GridPane.columnIndex="2" GridPane.rowIndex="6">
            <PasswordField fx:id="passwordField" promptText="8+ chars, letters &amp; digits"
                           styleClass="signup_field" prefWidth="260.0"/>
        </VBox>
        <Label text="Confirm Password" styleClass="signup_label"
               GridPane.columnIndex="1" GridPane.rowIndex="7">
            <font><Font name="System Bold" size="14.0"/></font>
        </Label>
        <VBox alignment="CENTER_LEFT" GridPane.columnIndex="2" GridPane.rowIndex="7">
            <PasswordField fx:id="confirmPasswordField" promptText="Re-enter password"
                           styleClass="signup_field" prefWidth="260.0"/>
        </VBox>
        <Label fx:id="statusLabel" text="" wrapText="true" prefWidth="380.0"
               styleClass="signup_status"
               GridPane.columnIndex="1" GridPane.rowIndex="8" GridPane.columnSpan="2"/>
        <VBox alignment="TOP_CENTER" spacing="10.0"
              GridPane.columnIndex="1" GridPane.rowIndex="9" GridPane.columnSpan="2">
            <Button fx:id="createAccountBtn" mnemonicParsing="false"
                    onAction="#createNewAccount" text="Create Account"
                    prefHeight="42.0" prefWidth="240.0" styleClass="btn_primary_large">
                <font><Font name="System Bold" size="15.0"/></font>
            </Button>
            <Button fx:id="goBackBtn" mnemonicParsing="false"
                    onAction="#goBack" text="← Back to Login"
                    prefHeight="38.0" prefWidth="240.0" styleClass="btn_secondary_large">
                <font><Font name="System Bold" size="13.0"/></font>
            </Button>
        </VBox>
    </children>
</GridPane>