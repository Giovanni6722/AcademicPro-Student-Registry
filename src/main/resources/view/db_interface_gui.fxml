<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:id="anchorPane" prefHeight="600.0" prefWidth="950.0"
            styleClass="anchor_pane"
            xmlns="http://javafx.com/javafx/20.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="viewmodel.DB_GUI_Controller">
    <children>
        <BorderPane fx:id="borderPane" prefHeight="600.0" prefWidth="950.0">

            <!-- MENU BAR -->
            <top>
                <MenuBar fx:id="menuBar" styleClass="menu_bar">
                    <menus>
                        <Menu text="File" styleClass="menu_options">
                            <items>
                                <MenuItem fx:id="newItem" onAction="#addRecord"
                                          text="New Record…" styleClass="menu_items"/>
                                <MenuItem onAction="#showImage"
                                          text="Change Profile Image" styleClass="menu_items"/>
                                <SeparatorMenuItem/>
                                <MenuItem onAction="#logOut"
                                          text="Log Out" styleClass="menu_items"/>
                                <MenuItem onAction="#closeApplication"
                                          text="Exit" styleClass="menu_items"/>
                            </items>
                        </Menu>
                        <Menu text="Edit" styleClass="menu_options">
                            <items>
                                <MenuItem fx:id="editItem" onAction="#editRecord"
                                          text="Edit Record    Ctrl+E" styleClass="menu_items"/>
                                <MenuItem fx:id="deleteItem" onAction="#deleteRecord"
                                          text="Delete Record  Ctrl+D" styleClass="menu_items"/>
                                <SeparatorMenuItem/>
                                <MenuItem onAction="#clearForm"
                                          text="Clear Form     Ctrl+R" styleClass="menu_items"/>
                            </items>
                        </Menu>
                        <Menu text="Data" styleClass="menu_options">
                            <items>
                                <MenuItem onAction="#importCSV"
                                          text="Import CSV…" styleClass="menu_items"/>
                                <MenuItem onAction="#exportCSV"
                                          text="Export CSV…" styleClass="menu_items"/>
                                <SeparatorMenuItem/>
                                <MenuItem onAction="#generatePDFReport"
                                          text="Generate PDF Report…" styleClass="menu_items"/>
                            </items>
                        </Menu>
                        <Menu text="Theme" styleClass="menu_options">
                            <items>
                                <MenuItem onAction="#lightTheme"
                                          text="Light Theme" styleClass="menu_items"/>
                                <MenuItem onAction="#darkTheme"
                                          text="Dark Theme" styleClass="menu_items"/>
                            </items>
                        </Menu>
                        <Menu text="Help" styleClass="menu_options">
                            <items>
                                <MenuItem onAction="#displayAbout"
                                          text="About AcademicPro" styleClass="menu_items"/>
                            </items>
                        </Menu>
                    </menus>
                </MenuBar>
            </top>

            <!-- LEFT PANEL -->
            <left>
                <VBox prefWidth="145.0" styleClass="left_pane">
                    <children>
                        <Label text="AcademicPro" styleClass="brand_label" wrapText="true">
                            <VBox.margin><Insets top="10.0" left="5.0" right="5.0"/></VBox.margin>
                        </Label>
                        <Label text="Student Registry" styleClass="brand_sub_label" wrapText="true">
                            <VBox.margin><Insets bottom="10.0" left="5.0" right="5.0"/></VBox.margin>
                        </Label>
                        <AnchorPane prefHeight="130.0" prefWidth="140.0">
                            <children>
                                <ImageView fx:id="img_view"
                                           fitHeight="120.0" fitWidth="130.0"
                                           layoutX="7.0" layoutY="5.0"
                                           onMouseClicked="#showImage"
                                           pickOnBounds="true" preserveRatio="true">
                                    <image><Image url="@../images/profile.png"/></image>
                                </ImageView>
                            </children>
                        </AnchorPane>
                        <Label text="Click image to change photo"
                               styleClass="hint_label" textAlignment="CENTER" wrapText="true">
                            <VBox.margin><Insets top="4.0" left="5.0" right="5.0"/></VBox.margin>
                        </Label>
                    </children>
                </VBox>
            </left>

            <!-- RIGHT PANEL (Form) -->
            <right>
                <VBox prefWidth="215.0" styleClass="form_pane">
                    <children>
                        <Label text="Student Details" styleClass="form_section_label">
                            <VBox.margin><Insets top="12.0" left="10.0" bottom="4.0"/></VBox.margin>
                        </Label>
                        <TextField fx:id="first_name" promptText="First Name" styleClass="text_field">
                            <VBox.margin><Insets left="10.0" right="10.0" top="4.0"/></VBox.margin>
                        </TextField>
                        <TextField fx:id="last_name" promptText="Last Name" styleClass="text_field">
                            <VBox.margin><Insets left="10.0" right="10.0" top="4.0"/></VBox.margin>
                        </TextField>
                        <TextField fx:id="department" promptText="Department" styleClass="text_field">
                            <VBox.margin><Insets left="10.0" right="10.0" top="4.0"/></VBox.margin>
                        </TextField>
                        <ComboBox fx:id="majorComboBox" promptText="Select Major"
                                  styleClass="combo_box" maxWidth="1.7976931348623157E308">
                            <VBox.margin><Insets left="10.0" right="10.0" top="4.0"/></VBox.margin>
                        </ComboBox>
                        <TextField fx:id="email" promptText="Email Address" styleClass="text_field">
                            <VBox.margin><Insets left="10.0" right="10.0" top="4.0"/></VBox.margin>
                        </TextField>
                        <TextField fx:id="imageURL" promptText="Image URL (optional)" styleClass="text_field">
                            <VBox.margin><Insets left="10.0" right="10.0" top="4.0"/></VBox.margin>
                        </TextField>
                        <Label text="" prefHeight="8.0"/>
                        <Button mnemonicParsing="false" onAction="#clearForm"
                                styleClass="btn_secondary" text="Clear">
                            <VBox.margin><Insets left="10.0" right="10.0" top="6.0"/></VBox.margin>
                        </Button>
                        <Button fx:id="addBtn" mnemonicParsing="false" onAction="#addNewRecord"
                                styleClass="btn_primary" text="Add Record">
                            <VBox.margin><Insets left="10.0" right="10.0" top="6.0"/></VBox.margin>
                        </Button>
                        <Button fx:id="editBtn" mnemonicParsing="false" onAction="#editRecord"
                                styleClass="btn_primary" text="Save Edit">
                            <VBox.margin><Insets left="10.0" right="10.0" top="6.0"/></VBox.margin>
                        </Button>
                        <Button fx:id="deleteBtn" mnemonicParsing="false" onAction="#deleteRecord"
                                styleClass="btn_danger" text="Delete">
                            <VBox.margin><Insets left="10.0" right="10.0" top="6.0"/></VBox.margin>
                        </Button>
                    </children>
                </VBox>
            </right>

            <!-- CENTER (Search + Table) -->
            <center>
                <VBox>
                    <HBox styleClass="search_bar_pane" alignment="CENTER_LEFT">
                        <Label text="🔍" style="-fx-font-size:14px;">
                            <HBox.margin><Insets left="8.0"/></HBox.margin>
                        </Label>
                        <TextField fx:id="searchField"
                                   promptText="Search by name, email, major, department…"
                                   styleClass="search_field" HBox.hgrow="ALWAYS">
                            <HBox.margin><Insets left="4.0" right="8.0" top="5.0" bottom="5.0"/></HBox.margin>
                        </TextField>
                        <Label fx:id="recordCountLabel" text="Records: 0"
                               styleClass="record_count_label">
                            <HBox.margin><Insets right="10.0"/></HBox.margin>
                        </Label>
                    </HBox>
                    <TableView fx:id="tv" onMouseClicked="#selectedItemTV"
                               VBox.vgrow="ALWAYS" styleClass="table_view">
                        <columns>
                            <TableColumn fx:id="tv_id"         prefWidth="45.0"  text="ID"/>
                            <TableColumn fx:id="tv_fn"         prefWidth="110.0" text="First Name"/>
                            <TableColumn fx:id="tv_ln"         prefWidth="110.0" text="Last Name"/>
                            <TableColumn fx:id="tv_department" prefWidth="130.0" text="Department"/>
                            <TableColumn fx:id="tv_major"      prefWidth="90.0"  text="Major"/>
                            <TableColumn fx:id="tv_email"      prefWidth="150.0" text="Email"/>
                        </columns>
                        <placeholder>
                            <Label text="No student records found." styleClass="table_placeholder"/>
                        </placeholder>
                    </TableView>
                </VBox>
            </center>

            <!-- STATUS BAR -->
            <bottom>
                <HBox prefHeight="30.0" styleClass="status_bar" alignment="CENTER_LEFT">
                    <Label fx:id="statusLabel" text="Ready" styleClass="status_label">
                        <HBox.margin><Insets left="12.0"/></HBox.margin>
                    </Label>
                    <Label fx:id="dbModeLabel" text="" styleClass="db_mode_label">
                        <HBox.margin><Insets left="20.0"/></HBox.margin>
                    </Label>
                </HBox>
            </bottom>

        </BorderPane>
    </children>
</AnchorPane>